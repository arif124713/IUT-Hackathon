# ─── Database (MySQL 8.0) ──────────────────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://root:yourpassword@localhost:3306/officepulse
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DATABASE=officepulse

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
# Get your key at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Discord ──────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your.discord.bot.token.here
# Right-click a channel → Copy Channel ID
ALERT_CHANNEL_ID=0

# ─── Timezone & Office Hours ──────────────────────────────────────────────────
TZ=Asia/Dhaka
OFFICE_OPEN=09:00
OFFICE_CLOSE=17:00

# ─── Simulator ────────────────────────────────────────────────────────────────
SIM_TICK_SECONDS=5
SIM_TIME_SCALE=1

# ─── Demo / Dev ───────────────────────────────────────────────────────────────
DEMO_MODE=false

# ─── Service URLs ─────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
MCP_SERVER_URL=http://localhost:8001

# ─── Backend ──────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── MCP Server ───────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8001

# ─── Alerts Engine ────────────────────────────────────────────────────────────
ALERTS_EVAL_SECONDS=30
MARATHON_MINUTES=120

# ─── Device Config ────────────────────────────────────────────────────────────
FANS_PER_ROOM=2
LIGHTS_PER_ROOM=3
